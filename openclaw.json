{
  "name": "EnglishPartner",
  "description": "英语陪练伙伴（查词+词根+发音+口语+AI例句+本地语法分析）",
  "version": "1.0.0",
  "author": "EnglishPartner Team",
  "contact": "partner@english.com",
  "updateTime": "2025-12-30",
  "mainAgent": "EnglishPartner_Main",
  "language": "zh-CN",
  "hotReload": true,
  "logConfig": {
    "level": "info",
    "path": "./logs/english_partner.log"
  },

  "agents": [
    {
      "name": "EnglishPartner_Main",
      "type": "main",
      "description": "英语学习主调度Agent",
      "workflows": [
        "word_query_workflow",
        "single_skill_workflow"
      ]
    },
    {
      "name": "WordTranslate_Agent",
      "type": "sub",
      "description": "单词双语翻译子Agent",
      "skills": ["Skill_WordQuery"],
      "inputSchema": {
        "type": "object",
        "required": ["word"],
        "properties": {
          "word": {
            "type": "string",
            "description": "待查询单词（小写）"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "word": "string",
          "pos": "array",
          "cn_meaning": "string",
          "collocation": "array",
          "example_sentence": "string"
        }
      }
    },
    {
      "name": "RootAffix_Agent",
      "type": "sub",
      "description": "词根词缀解析子Agent",
      "skills": ["Skill_RootAnalyze"],
      "inputSchema": {
        "type": "object",
        "required": ["word"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "root": "string",
          "prefix": "string",
          "suffix": "string",
          "memo_tip": "string",
          "relative_words": "array"
        }
      }
    },
    {
      "name": "Pronunciation_Agent",
      "type": "sub",
      "description": "音标发音子Agent",
      "skills": ["Skill_Pronounce"],
      "inputSchema": {
        "type": "object",
        "required": ["word"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "phonetic_uk": "string",
          "phonetic_us": "string",
          "stress_visual": "string",
          "phonetic_tip_cn": "string"
        }
      }
    },
    {
      "name": "GrammarSentence_Agent",
      "type": "sub",
      "description": "例句语法本地脚本解析Agent",
      "skills": ["Skill_GrammarAnalyze"],
      "inputSchema": {
        "type": "object",
        "required": ["generated_sentence"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "pattern_key": "string",
          "pattern_name": "string",
          "original_sentence": "string",
          "grammar_analysis": "array",
          "difficulty": "string",
          "grammar_type": "string",
          "sentence_structure": "string"
        }
      }
    }
  ],

  "skills": [
    {
      "name": "Skill_WordQuery",
      "type": "local_data",
      "description": "本地双语词库查询 + AI生成例句",
      "dataPath": "datas/word_lib.json",
      "searchField": "word_lower",
      "matchMode": "exact",
      "fallbackMode": "fuzzy",
      "capabilities": [
        "单词查询",
        "中英释义",
        "词性标注",
        "固定搭配",
        "AI例句生成"
      ],
      "errorMsg": "未在本地词库中找到「{word}」，请尝试其他单词"
    },
    {
      "name": "Skill_RootAnalyze",
      "type": "local_data",
      "description": "词根词缀本地查询",
      "dataPath": "datas/root_lib.json",
      "searchField": "word_lower",
      "matchMode": "exact",
      "fallbackMode": "fuzzy",
      "capabilities": ["词根拆解", "词缀解析", "记忆技巧"],
      "errorMsg": "「{word}」暂无词根解析信息"
    },
    {
      "name": "Skill_Pronounce",
      "type": "local_data",
      "description": "发音与音标查询",
      "dataPath": "datas/pronounce_lib.json",
      "searchField": "word_lower",
      "matchMode": "exact",
      "fallbackMode": "fuzzy",
      "capabilities": ["英美音标", "重音提示", "发音技巧"],
      "errorMsg": "「{word}」暂无发音信息"
    },
    {
      "name": "Skill_GrammarAnalyze",
      "type": "local_script",
      "description": "本地脚本语法分析（零AI Token消耗）",
      "scriptPath": "./grammar_engine.py",
      "inputType": "generated_sentence",
      "outputType": "grammar_result",
      "capabilities": [
        "句型匹配",
        "句子成分",
        "语法考点",
        "难度标注"
      ],
      "errorMsg": "例句语法分析暂不可用"
    }
  ],

  "workflows": [
    {
      "name": "word_query_workflow",
      "description": "单词全功能查询 + AI例句 + 本地语法分析",
      "trigger": "用户输入纯英文单词",
      "triggerRule": {
        "type": "regex",
        "pattern": "^[a-zA-Z]{1,20}$",
        "ignoreCase": true
      },
      "steps": [
        {
          "agent": "WordTranslate_Agent",
          "skill": "Skill_WordQuery",
          "mode": "sync"
        },
        {
          "agent": "RootAffix_Agent",
          "skill": "Skill_RootAnalyze",
          "mode": "parallel"
        },
        {
          "agent": "Pronunciation_Agent",
          "skill": "Skill_Pronounce",
          "mode": "parallel"
        },
        {
          "agent": "GrammarSentence_Agent",
          "skill": "Skill_GrammarAnalyze",
          "mode": "sync",
          "transferData": "generated_sentence"
        }
      ],
      "outputMerge": {
        "format": "structured",
        "order": [
          "WordTranslate_Agent",
          "Pronunciation_Agent",
          "RootAffix_Agent",
          "GrammarSentence_Agent"
        ],
        "emptyValue": "暂无相关信息"
      }
    },
    {
      "name": "single_skill_workflow",
      "description": "单一功能查询流程",
      "trigger": "用户仅查发音/仅查词根/仅查翻译",
      "steps": [
        {
          "agent": "dynamic",
          "skill": "dynamic",
          "mode": "single",
          "matchRule": {
            "intentKeyword": {
              "发音": ["怎么读", "发音", "音标", "读法"],
              "词根": ["词根", "词缀", "拆解", "记忆", "构词"],
              "翻译": ["意思", "翻译", "释义", "含义"]
            },
            "defaultAgent": "WordTranslate_Agent",
            "defaultSkill": "Skill_WordQuery"
          }
        }
      ]
    }
  ]
}
